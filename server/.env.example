# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/examsathi

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret

# ─── Anthropic (Claude AI) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Razorpay (Payments) ─────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─── Email (SMTP via Gmail) ───────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=ExamSathi <noreply@examsathi.in>

# ─── Client ───────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:4200
